{
  "source": {
    "include": ["index.js", "routes", "middlewares", "utils"],
    "includePattern": ".+\\.js$",
    "exclude": ["node_modules", "docs", "coverage", "__tests__"]
  },
  "opts": {
    "destination": "docs/generated/backend",
    "recurse": true,
    "readme": "../README.md"
  },
  "plugins": ["plugins/markdown"]
}